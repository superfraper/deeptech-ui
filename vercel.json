{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://deeptech-production.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/" }
  ],
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "framework": null
}
