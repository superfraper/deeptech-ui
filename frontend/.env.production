# REACT_APP_API_URL is intentionally NOT set here.
# In production (Vercel), the app uses window.location.origin so that
# /api/* calls are proxied by Vercel to Railway (see vercel.json rewrites).
# For local dev, set REACT_APP_API_URL=http://localhost:8000 in .env.local
ESLINT_NO_DEV_ERRORS=true
DISABLE_ESLINT_PLUGIN=true
CI=false
GENERATE_SOURCEMAP=false
